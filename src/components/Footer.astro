---
import { site } from "../data/site";

const socialEntries = Object.entries(site.socialLinks).filter(
  (entry): entry is [string, string] => typeof entry[1] === "string" && entry[1].length > 0
);

const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-border">
  <div
    class="mx-auto flex max-w-[1140px] flex-col gap-4 px-6 py-8 text-sm text-muted sm:flex-row sm:items-center sm:justify-between"
  >
    <p>© {year} {site.name}</p>
    {
      socialEntries.length > 0 && (
        <ul class="flex gap-5">
          {socialEntries.map(([label, href]) => (
            <li>
              <a
                href={href}
                class="capitalize transition-colors hover:text-text"
                rel={href.startsWith("http") ? "me noopener" : undefined}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</footer>
