---
import type { CollectionEntry } from "astro:content";
import {
  statusBadgeClass,
  getProjectLinks,
  getCoverImage,
} from "../lib/projects";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { data } = project;
const slug = data.slug ?? project.id;

const links = getProjectLinks(data.links);
const coverImage = getCoverImage(data.images);
---

<article
  class="group border border-border rounded-lg overflow-hidden hover:border-accent transition-colors"
>
  {
    coverImage && (
      <div class="aspect-video overflow-hidden">
        <img
          src={coverImage.src}
          alt={coverImage.alt}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          loading="lazy"
        />
      </div>
    )
  }

  <div class="p-4">
    <div class="flex items-start justify-between gap-3">
      <h3 class="font-medium text-text group-hover:text-accent transition-colors">
        <a href={`/projects/${slug}`}>{data.title}</a>
      </h3>
      <span class={statusBadgeClass(data.status)}>{data.status}</span>
    </div>

    <p class="mt-2 text-sm text-muted">{data.summary}</p>

    {
      data.topics.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {data.topics.map((topic) => (
            <span class="rounded-full bg-surface px-2 py-0.5 text-xs text-muted">
              #{topic}
            </span>
          ))}
        </div>
      )
    }

    {
      links.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-3 text-xs">
          {links.map((link) => (
            <a
              href={link.href}
              class="text-muted hover:text-text transition-colors underline decoration-border underline-offset-2"
              rel="noopener"
              target="_blank"
            >
              {link.label}
            </a>
          ))}
        </div>
      )
    }
  </div>
</article>
