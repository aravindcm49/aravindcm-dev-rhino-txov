---
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import "@fontsource/geist-mono/400.css";
import "@fontsource/geist-mono/500.css";
import "../styles/global.css";
import { themeInitScript } from "../lib/theme";
import ThemeToggle from "../components/ThemeToggle";

interface Props {
  title: string;
  active: "publish" | "feed" | "people";
}

const { title, active } = Astro.props;

const navItems = [
  { label: "Publish", href: "/admin/publish", key: "publish" as const },
  { label: "Feed", href: "/admin/feed", key: "feed" as const },
  { label: "People", href: "/admin/people", key: "people" as const },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <script is:inline set:html={themeInitScript} />
    <title>{title} — Admin</title>
  </head>
  <body class="min-h-screen bg-neutral-50 text-neutral-900 dark:bg-neutral-950 dark:text-neutral-100">
    <header class="border-b border-neutral-200 dark:border-neutral-800">
      <div class="mx-auto max-w-[1140px] px-6 py-4 flex items-center justify-between">
        <a href="/admin/publish" class="font-semibold text-lg">Admin</a>
        <nav class="flex gap-6 items-center">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                "text-sm font-medium transition-colors",
                active === item.key
                  ? "text-neutral-900 dark:text-neutral-100 border-b-2 border-neutral-900 dark:border-neutral-100 pb-1"
                  : "text-neutral-500 hover:text-neutral-700 dark:text-neutral-400 dark:hover:text-neutral-200",
              ]}
            >
              {item.label}
            </a>
          ))}
          <ThemeToggle client:load />
        </nav>
      </div>
    </header>
    <main class="mx-auto max-w-[1140px] px-6 py-8">
      <slot />
    </main>
  </body>
</html>
