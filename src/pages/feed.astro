---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import FeedFilter from "../components/FeedFilter";
import type { FeedItemLike } from "../lib/feedFilter";

const [allFeed, allPeople] = await Promise.all([
  getCollection("feed"),
  getCollection("people"),
]);

// Serialize to a JSON-safe shape. Dates become ISO strings because React
// islands receive props through JSON and Date objects don't survive that.
const items: FeedItemLike[] = allFeed
  .filter((e) => !e.data.draft)
  .map((e) => ({
    id: e.data.slug ?? e.id,
    title: e.data.title,
    summary: e.data.summary,
    commentary: e.data.commentary,
    type: e.data.type,
    topics: e.data.topics,
    people: e.data.people,
    source: e.data.source,
    publishedAt: e.data.publishedAt.toISOString(),
    activityAt: e.data.activityAt?.toISOString(),
    hasPage: e.data.hasPage,
  }));

const people = allPeople.map((p) => ({ id: p.id, name: p.data.name }));
---

<BaseLayout
  title="Feed"
  description="Writing, notes, links, tweets, videos, papers, and books — a mixed stream with commentary."
>
  <FeedFilter client:load items={items} people={people} />
</BaseLayout>
