---
export const prerender = false;

import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import FeedFilter from "../components/FeedFilter";
import { mergeFeedItems } from "../lib/db-feed";
import { db } from "../lib/db/index";
import { getPublishedFeedItems } from "../lib/db/feed-items";
import { getAllPeople } from "../lib/db/people";

const [mdxFeed, dbItems, dbPeople] = await Promise.all([
  getCollection("feed"),
  getPublishedFeedItems(db).catch(() => []),
  getAllPeople(db).catch(() => []),
]);

const items = mergeFeedItems(mdxFeed, dbItems);

const people = dbPeople.map((p) => ({ id: p.id, name: p.name }));
---

<BaseLayout
  title="Feed"
  description="Writing, notes, links, tweets, videos, papers, and books — a mixed stream with commentary."
>
  <FeedFilter client:load items={items} people={people} />
</BaseLayout>
