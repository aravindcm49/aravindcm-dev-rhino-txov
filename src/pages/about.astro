---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";

const pages = await getCollection("pages");
const aboutEntry = pages.find((p) => p.id === "about");

if (!aboutEntry) {
  throw new Error("About page content not found");
}

const { Content } = await render(aboutEntry);
const { data } = aboutEntry;
---

<BaseLayout
  title={data.title}
  description={data.description}
  canonical="/about"
>
  <article class="mx-auto max-w-[720px]">
    <header class="mb-8">
      <h1 class="text-2xl font-semibold text-text">{data.title}</h1>
      <p class="mt-2 text-muted">{data.description}</p>
    </header>

    <div class="prose prose-neutral max-w-none dark:prose-invert">
      <Content />
    </div>

    <section class="mt-12 border-t border-border pt-8">
      <h2 class="text-lg font-medium text-text">Connect</h2>
      <ul class="mt-4 flex flex-wrap gap-4 text-sm">
        {
          site.socialLinks.github && (
            <li>
              <a
                href={site.socialLinks.github}
                class="text-muted hover:text-text transition-colors"
                rel="me noopener"
                target="_blank"
              >
                GitHub
              </a>
            </li>
          )
        }
        {
          site.socialLinks.twitter && (
            <li>
              <a
                href={site.socialLinks.twitter}
                class="text-muted hover:text-text transition-colors"
                rel="me noopener"
                target="_blank"
              >
                Twitter
              </a>
            </li>
          )
        }
        {
          site.socialLinks.linkedin && (
            <li>
              <a
                href={site.socialLinks.linkedin}
                class="text-muted hover:text-text transition-colors"
                rel="me noopener"
                target="_blank"
              >
                LinkedIn
              </a>
            </li>
          )
        }
        {
          site.socialLinks.rss && (
            <li>
              <a
                href={site.socialLinks.rss}
                class="text-muted hover:text-text transition-colors"
              >
                RSS
              </a>
            </li>
          )
        }
      </ul>
    </section>
  </article>
</BaseLayout>
