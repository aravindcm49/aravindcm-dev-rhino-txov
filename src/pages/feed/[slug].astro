---
export const prerender = false;

import { getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { isPageable, prepareFeedPage } from "../../lib/feedDetail";
import { getFeedItemBySlug } from "../../lib/db/feed-items";
import { getAllPeople as getAllDbPeople } from "../../lib/db/people";
import { normalizeDbItem } from "../../lib/db-feed";
import { renderMarkdown } from "../../lib/markdown";
import { describeSource } from "../../lib/feed";
import { db } from "../../lib/db/index";

const { slug } = Astro.params;

// Try MDX first
const mdxEntry = await getEntry("feed", slug ?? "");
const isMdx = mdxEntry !== undefined && isPageable(mdxEntry);

let mdxPage: ReturnType<typeof prepareFeedPage> | null = null;
let mdxContent: Awaited<ReturnType<typeof render>>["Content"] | null = null;
let dbHtml = "";
let dbTitle = "";
let dbSummary = "";
let dbCommentary: string | undefined;
let dbType = "";
let dbPublishedDate = "";
let dbUpdatedDate: string | undefined;
let dbCanonical = "";
let dbSource: ReturnType<typeof describeSource> = undefined;
let dbResolvedPeople: { id: string; name: string }[] = [];
let dbTopics: string[] = [];

if (isMdx && mdxEntry) {
  const allPeople = await getAllDbPeople(db).catch(() => []);
  const peoplePool = allPeople.map((p) => ({ id: p.id, name: p.name }));
  mdxPage = prepareFeedPage(mdxEntry, peoplePool);
  const rendered = await render(mdxEntry);
  mdxContent = rendered.Content;
} else {
  // Try DB
  const dbRow = await getFeedItemBySlug(db, slug ?? "").catch(() => null);

  if (dbRow && dbRow.hasPage && !dbRow.draft) {
    const normalized = normalizeDbItem(dbRow);
    dbHtml = dbRow.content ? renderMarkdown(dbRow.content) : "";
    const allPeople = await getAllDbPeople(db).catch(() => []);
    const peoplePool = allPeople.map((p) => ({ id: p.id, name: p.name }));

    dbResolvedPeople = (dbRow.people ?? [])
      .map((pid: string) => peoplePool.find((p) => p.id === pid))
      .filter((p): p is { id: string; name: string } => p !== undefined);

    dbTitle = normalized.title;
    dbSummary = normalized.summary;
    dbCommentary = normalized.commentary;
    dbType = normalized.type;
    dbPublishedDate = normalized.publishedAt.toISOString().split("T")[0];
    dbUpdatedDate = normalized.updatedAt?.toISOString().split("T")[0];
    dbCanonical = `/feed/${dbRow.slug}`;
    dbSource = describeSource(normalized.source);
    dbTopics = normalized.topics ?? [];
  } else {
    return new Response("Not found", { status: 404 });
  }
}

const showMdx = isMdx && mdxPage && mdxContent;
---

{showMdx && mdxPage && mdxContent && (
  <BaseLayout
    title={mdxPage.title}
    description={mdxPage.summary}
    canonical={`/feed/${mdxPage.slug}`}
    type="article"
  >
    <article class="mx-auto max-w-[720px]">
      <header class="mb-8">
        <div class="flex items-baseline gap-3">
          <h1 class="text-2xl font-semibold text-text">{mdxPage.title}</h1>
          <span class="shrink-0 font-mono text-xs uppercase tracking-wide text-muted">
            {mdxPage.type}
          </span>
        </div>
        <p class="mt-3 text-base text-muted">{mdxPage.summary}</p>
        <time
          datetime={mdxPage.publishedAt.toISOString().split("T")[0]}
          class="mt-2 block font-mono text-xs text-muted"
        >
          {mdxPage.publishedAt.toISOString().split("T")[0]}
          {mdxPage.updatedAt && ` · updated ${mdxPage.updatedAt.toISOString().split("T")[0]}`}
        </time>
      </header>

      {mdxPage.commentary && (
        <div class="mb-8 border-l-2 border-accent pl-4">
          <p class="text-lg leading-relaxed text-text">{mdxPage.commentary}</p>
        </div>
      )}

      {mdxPage.source && (
        <div class="mb-8 rounded-lg bg-surface p-4">
          <p class="font-mono text-xs text-muted">Source</p>
          {mdxPage.source.href ? (
            <a
              href={mdxPage.source.href}
              class="mt-1 block text-sm font-medium text-text underline decoration-border underline-offset-2 hover:text-accent hover:decoration-accent transition-colors"
              rel="noopener"
              target="_blank"
            >
              {mdxPage.source.label}
            </a>
          ) : (
            <p class="mt-1 text-sm font-medium text-text">{mdxPage.source.label}</p>
          )}
        </div>
      )}

      {(mdxPage.people.length > 0 || mdxPage.topics.length > 0) && (
        <div class="mb-8 flex flex-wrap gap-2 text-xs">
          {mdxPage.people.map((p) => (
            <a
              href={`/feed?person=${p.id}`}
              class="rounded-full border border-border px-2.5 py-1 text-muted hover:text-text hover:border-accent transition-colors"
            >
              {p.name}
            </a>
          ))}
          {mdxPage.topics.map((topic: string) => (
            <a
              href={`/feed?topic=${topic}`}
              class="rounded-full bg-surface px-2.5 py-1 text-muted hover:text-text transition-colors"
            >
              #{topic}
            </a>
          ))}
        </div>
      )}

      <div class="prose prose-neutral max-w-none dark:prose-invert">
        <mdxContent />
      </div>
    </article>
  </BaseLayout>
)}

{!showMdx && (
  <BaseLayout
    title={dbTitle}
    description={dbSummary}
    canonical={dbCanonical}
    type="article"
  >
    <article class="mx-auto max-w-[720px]">
      <header class="mb-8">
        <div class="flex items-baseline gap-3">
          <h1 class="text-2xl font-semibold text-text">{dbTitle}</h1>
          <span class="shrink-0 font-mono text-xs uppercase tracking-wide text-muted">
            {dbType}
          </span>
        </div>
        <p class="mt-3 text-base text-muted">{dbSummary}</p>
        <time
          datetime={dbPublishedDate}
          class="mt-2 block font-mono text-xs text-muted"
        >
          {dbPublishedDate}
          {dbUpdatedDate && ` · updated ${dbUpdatedDate}`}
        </time>
      </header>

      {dbCommentary && (
        <div class="mb-8 border-l-2 border-accent pl-4">
          <p class="text-lg leading-relaxed text-text">{dbCommentary}</p>
        </div>
      )}

      {dbSource && (
        <div class="mb-8 rounded-lg bg-surface p-4">
          <p class="font-mono text-xs text-muted">Source</p>
          {dbSource.href ? (
            <a
              href={dbSource.href}
              class="mt-1 block text-sm font-medium text-text underline decoration-border underline-offset-2 hover:text-accent hover:decoration-accent transition-colors"
              rel="noopener"
              target="_blank"
            >
              {dbSource.label}
            </a>
          ) : (
            <p class="mt-1 text-sm font-medium text-text">{dbSource.label}</p>
          )}
        </div>
      )}

      {(dbResolvedPeople.length > 0 || dbTopics.length > 0) && (
        <div class="mb-8 flex flex-wrap gap-2 text-xs">
          {dbResolvedPeople.map((p) => (
            <a
              href={`/feed?person=${p.id}`}
              class="rounded-full border border-border px-2.5 py-1 text-muted hover:text-text hover:border-accent transition-colors"
            >
              {p.name}
            </a>
          ))}
          {dbTopics.map((topic: string) => (
            <a
              href={`/feed?topic=${topic}`}
              class="rounded-full bg-surface px-2.5 py-1 text-muted hover:text-text transition-colors"
            >
              #{topic}
            </a>
          ))}
        </div>
      )}

      {dbHtml && (
        <div class="prose prose-neutral max-w-none dark:prose-invert" set:html={dbHtml} />
      )}
    </article>
  </BaseLayout>
)}
